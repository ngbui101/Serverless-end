MINIO_ENDPOINT=http://<vps3-host>:9000
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key>
MINIO_REGION=us-east-1
MINIO_BUCKET_NAME=images-raw-classic
MINIO_PUBLIC_URL=http://<vps3-host>:9000

PROMETHEUS_REMOTE_WRITE_URL=http://<vps3-host>:9090/api/v1/write
PRESIGN_EXPIRES_SECONDS=300
IMAGE_CONTENT_TYPE=image/png

VPS2_SSH_HOST=<vps3-host>
VPS2_SSH_USER=ubuntu
VPS2_SSH_KEY=/path/to/vps3-key

VPS3_SSH_HOST=<vps3-host>
VPS3_SSH_USER=ubuntu
VPS3_SSH_KEY=/path/to/vps3-key
